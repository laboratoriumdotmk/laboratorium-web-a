# Database
DATABASE_URI=postgresql://laboratorium:laboratorium@127.0.0.1:5432/laboratorium

# Payload
PAYLOAD_SECRET=your-secret-here-change-in-production

# Next.js
NEXT_PUBLIC_SERVER_URL=http://localhost:3100

# Cloudflare R2 (S3-compatible) — leave empty for local disk storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Email — Resend (leave empty to disable email)
RESEND_API_KEY=

# Contact form notification recipient
CONTACT_EMAIL=contact@laboratorium.mk

# Optional: Analytics (Plausible domain)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
